local function notify(msg)
    notifLabel.Text = " → " .. msg
    notifFrame.Visible = true
    TweenService:Create(notifFrame, TweenInfo.new(0.3), {BackgroundTransparency = 0.1}):Play()
    task.delay(2, function()
        TweenService:Create(notifFrame, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        task.wait(0.5)
        notifFrame.Visible = false
    end)
end

-- FEATURES (shortened)
local function headlockFeature(state)
    if state then
        taskHandles.headlock = task.spawn(function()
            local hum = char:WaitForChild("Humanoid")
            local anim = Instance.new("Animation"); anim.AnimationId = "rbxassetid://118465365906714"
            local track = hum:WaitForChild("Animator"):LoadAnimation(anim)
            track.Priority = Enum.AnimationPriority.Action4
            animationTracks.headlock = track
            local keys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
            while true do track:Play() keys:FireServer("DamageTool") task.wait(2) end
        end)
    else
        if taskHandles.headlock then task.cancel(taskHandles.headlock) taskHandles.headlock = nil end
        if animationTracks.headlock then animationTracks.headlock:Stop() animationTracks.headlock = nil end
    end
    notify("Headlock " .. (state and "ON" or "OFF"))
end

