local function autoEscapeFeature(state)
    if state then
        taskHandles.autoescape = task.spawn(function()
            local ev = ReplicatedStorage.events.ValueChange
            while true do
                local escaped = char and char:FindFirstChild("Player") and char.Player.Damages and char.Player.Damages.values and char.Player.Damages.values.DamageTool and char.Player.Damages.values.DamageTool.Escaped
